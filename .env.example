# LANCE — Environment Configuration
# Copy this to .env and fill in your API keys

# ── LLM Provider Keys ──────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Ollama runs locally — no key needed
# Default: http://localhost:11434
OLLAMA_BASE_URL=http://localhost:11434

# ── Judge Model ────────────────────────────────────────────────────────────
# The LLM used to score attack responses.
# Use ollama/llama3 for FREE local scoring (no API cost).
# Use openai/gpt-4o-mini for better accuracy (~$0.0001/call).
JUDGE_MODEL=ollama/llama3

# ── Database ───────────────────────────────────────────────────────────────
# SQLite (local, zero config):
DATABASE_URL=sqlite:///./lance.db
# PostgreSQL (cloud deployment):
# DATABASE_URL=postgresql://user:pass@host:5432/lance

# ── API Server ─────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Report Branding ────────────────────────────────────────────────────────
ORG_NAME=iosec.in
ASSESSOR_NAME=Shekhar Suman

# ── Performance ────────────────────────────────────────────────────────────
MAX_CONCURRENT_PROBES=5
PROBE_TIMEOUT_SECONDS=30
